{
  "manifest_version": 3,
  "name": "ToS Shield",
  "version": "1.0",
  "description": "Privacy-first AI that detects Dark Patterns in TOS.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "offscreen"
  ],
  "action": {
    "default_popup": "index.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "wasm/*.wasm"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}